{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:3455",
    "ANTHROPIC_AUTH_TOKEN": "sk-xxx",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "gemini-3.1-flash-lite-preview"
  },
  "permissions": {
    "allow": [
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(pwd*)",
      "Bash(which*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(du*)",
      "Bash(df*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run pytest*)",
      "Bash(uv run mypy*)",
      "Bash(uv run black*)",
      "Bash(fd *)",
      "Bash(tree *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Read(.gitignore)",
      "Read(.claude/settings.json)",
      "Read(.claude/CLAUDE.md)",
      "Read(.claude/rules/*)",
      "Read(.claude/guidelines/*)",
      "Write(.claude/todos/*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(*.pem)",
      "Read(secrets.yaml)",
      "Read(credentials.json)",
      "Read(*.key)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",
      "Bash(sudo*)",
      "Bash(chmod*)",
      "Bash(chown*)",
      "Bash(kill*)",
      "Bash(systemctl*)",
      "Bash(service*)",
      "Bash(docker*)",
      "Bash(podman*)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.env|*.pem|*secrets.yaml|*credentials.json|*.key|id_rsa*|id_ed25519*) echo '{\"block\": true, \"message\": \"Cannot edit sensitive files.\"}' >&2; exit 2 ;; esac",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // empty'); case \"$CMD\" in *rm\\ -rf\\ /*|*mkfs*|*dd\\ if=*) echo '{\"block\": true, \"message\": \"Dangerous command blocked.\"}' >&2; exit 2 ;; esac",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.py) uv run ruff format \"$FILE\" && uv run ruff check --fix \"$FILE\" ;; esac",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Claude Code session started at '$(date)",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash /home/zulu/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "repomix-mcp@repomix": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "dangerouslyDisableNaiveFiltering": false
}
